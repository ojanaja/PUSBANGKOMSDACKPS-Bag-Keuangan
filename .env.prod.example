POSTGRES_USER=siap_admin
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=siap_bpk

JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Comma-separated frontend origins allowed for CORS.
# If frontend and API are on the same domain via nginx reverse proxy,
# this can be set to your public app URL only.
CORS_ALLOW_ORIGINS=https://app.example.go.id

# Cookie settings for public HTTPS deployment
COOKIE_SAME_SITE=Lax
